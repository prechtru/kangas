---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("news");

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | Kangas Community Basketball Club`} description={entry.data.excerpt}>
  <article class="post-shell panel">
    <div class="post-meta">
      <span>{entry.data.category}</span>
      <time datetime={entry.data.publishDate.toISOString()}>
        {entry.data.publishDate.toLocaleDateString("en-AU", {
          day: "numeric",
          month: "long",
          year: "numeric"
        })}
      </time>
    </div>

    <h1>{entry.data.title}</h1>
    <p class="post-excerpt">{entry.data.excerpt}</p>
    <p class="post-author">By {entry.data.author}</p>

    <div class="post-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post-shell {
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--accent-deep);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.78rem;
    font-weight: 800;
  }

  h1 {
    margin: 1rem 0 0.75rem;
    max-width: 18ch;
    font-size: clamp(2.4rem, 7vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .post-excerpt,
  .post-author,
  .post-body :global(p),
  .post-body :global(li) {
    color: var(--muted);
    line-height: 1.8;
  }

  .post-body {
    margin-top: 2rem;
    max-width: 72ch;
  }

  .post-body :global(h2),
  .post-body :global(h3) {
    margin-top: 2rem;
  }

  @media (max-width: 720px) {
    .post-meta {
      flex-direction: column;
    }
  }
</style>
