---
interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  slantTo?: "light" | "yellow";
}

const { eyebrow, title, summary, slantTo = "light" } = Astro.props;
const slantClass = slantTo === "yellow" ? "bg-primary-container" : "bg-tertiary-fixed";
---

<section class="relative overflow-hidden pb-16 pt-[5rem]">
  <div class="section-wrap py-12">
    <div class="max-w-4xl">
      <div class="parallelogram mb-5 inline-block border border-primary-container bg-transparent px-4 py-1">
        <span class="skew-fix block text-sm font-black italic uppercase tracking-widest text-primary-container">{eyebrow}</span>
      </div>
      <h1 class="font-display-lg text-4xl font-black italic uppercase leading-none text-white sm:text-5xl md:text-6xl">{title}</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-zinc-300">{summary}</p>
    </div>
  </div>
  <div class="absolute inset-x-0 -bottom-[2px] h-[calc(4rem+4px)] bg-background">
    <div class={`divider-angle-fill ${slantClass}`}></div>
  </div>
</section>
