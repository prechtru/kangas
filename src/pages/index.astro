---
import { getEntry, getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/withBase";

const home = await getEntry("pages", "home");

if (!home) {
  throw new Error("Missing home page content entry.");
}

const news = await getCollection("news");
const featuredNews = news
  .filter((entry) => entry.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 2);

const { Content } = await render(home);
const { hero, highlights, programs } = home.data;
---

<BaseLayout title={home.data.metaTitle ?? home.data.title} description={home.data.metaDescription}>
  <section class="hero panel">
    <div class="hero-copy">
      <span class="eyebrow">{hero.eyebrow}</span>
      <h1>{hero.headline}</h1>
      <p>{hero.subheadline}</p>
      <div class="button-row">
        <a class="button button-primary" href={withBase(hero.primaryCtaHref)}>{hero.primaryCtaLabel}</a>
        <a class="button button-secondary" href={withBase(hero.secondaryCtaHref)}>{hero.secondaryCtaLabel}</a>
      </div>
    </div>

    <div class="hero-aside">
      <div class="court-card">
        <p>Club Snapshot</p>
        <div class="stat-grid">
          {hero.stats.map((stat) => (
            <article>
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="content-grid">
    <div class="panel intro-card">
      <div class="prose">
        <Content />
      </div>
    </div>

    <div class="panel latest-card">
      <span class="eyebrow">Latest news</span>
      <h2 class="section-title">What’s happening around the club.</h2>
      <div class="news-stack">
        {featuredNews.map((entry) => (
          <a class="news-teaser" href={withBase(`/news/${entry.slug}/`)}>
            <span>{entry.data.category}</span>
            <strong>{entry.data.title}</strong>
            <p>{entry.data.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="highlights">
    <div>
      <span class="eyebrow">Why families join</span>
      <h2 class="section-title">A club built for connection, confidence, and consistent growth.</h2>
    </div>
    <div class="card-grid">
      {highlights.map((item) => (
        <article class="panel feature-card">
          <h3>{item.title}</h3>
          <p>{item.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="programs">
    <div>
      <span class="eyebrow">Programs</span>
      <h2 class="section-title">Basketball pathways for kids, teens, and adults.</h2>
    </div>
    <div class="card-grid">
      {programs.map((program) => (
        <article class="panel program-card">
          <p class="program-audience">{program.audience}</p>
          <h3>{program.name}</h3>
          <p>{program.summary}</p>
          <small>{program.schedule}</small>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.35fr 0.95fr;
    gap: 2rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    overflow: hidden;
  }

  .hero-copy h1 {
    margin: 1rem 0;
    max-width: 11ch;
    font-size: clamp(3rem, 9vw, 6.4rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .hero-copy p {
    max-width: 58ch;
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .hero-aside {
    display: flex;
    align-items: stretch;
  }

  .court-card {
    position: relative;
    width: 100%;
    min-height: 100%;
    padding: 1.5rem;
    border-radius: calc(var(--radius) - 8px);
    background:
      linear-gradient(135deg, rgba(24, 59, 99, 0.96), rgba(16, 32, 51, 0.98)),
      linear-gradient(180deg, #183b63, #102033);
    color: white;
    overflow: hidden;
  }

  .court-card::before,
  .court-card::after {
    position: absolute;
    content: "";
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
  }

  .court-card::before {
    inset: auto -18% -8% auto;
    width: 240px;
    height: 240px;
  }

  .court-card::after {
    inset: 16% auto auto -22%;
    width: 260px;
    height: 260px;
  }

  .court-card > p {
    position: relative;
    z-index: 1;
    margin: 0 0 1rem;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
  }

  .stat-grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .stat-grid article {
    padding: 1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(6px);
  }

  .stat-grid strong {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 2rem;
    line-height: 1;
  }

  .stat-grid span {
    color: rgba(255, 255, 255, 0.76);
  }

  .content-grid,
  .highlights,
  .programs {
    margin-top: 2rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 1.5rem;
  }

  .intro-card,
  .latest-card,
  .feature-card,
  .program-card {
    padding: 1.5rem;
  }

  .prose :global(h2) {
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
  }

  .prose :global(p),
  .prose :global(li) {
    color: var(--muted);
    line-height: 1.7;
  }

  .news-stack {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .news-teaser {
    display: block;
    padding: 1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--line);
  }

  .news-teaser span,
  .program-audience {
    color: var(--accent-deep);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .news-teaser strong,
  .feature-card h3,
  .program-card h3 {
    display: block;
    margin: 0.6rem 0;
    font-size: 1.2rem;
  }

  .news-teaser p,
  .feature-card p,
  .program-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .program-card small {
    display: inline-block;
    margin-top: 1rem;
    color: var(--ink-soft);
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .hero,
    .content-grid,
    .card-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: 100%;
    }
  }
</style>
