---
import ButtonLink from "./ButtonLink.astro";

interface NewsEntry {
  slug: string;
  data: {
    title: string;
    excerpt: string;
    publishDate: Date;
    author: string;
    category: string;
  };
}

interface Props {
  entries: NewsEntry[];
}

const { entries } = Astro.props;
---

<section class="relative bg-tertiary-fixed py-10 pb-24 text-surface md:py-12 md:pb-28">
  <div class="section-wrap">
    <div class="grid gap-5">
      {entries.map((entry) => (
        <article class="border border-black/10 bg-white p-5 shadow-sm md:p-6">
          <div class="flex flex-col gap-2 text-sm font-black uppercase tracking-[0.18em] text-[#765b00] md:flex-row md:items-center md:justify-between">
            <span>{entry.data.category}</span>
            <time datetime={entry.data.publishDate.toISOString()}>
              {entry.data.publishDate.toLocaleDateString("en-AU", { day: "numeric", month: "long", year: "numeric" })}
            </time>
          </div>
          <h2 class="mt-3 font-headline-lg text-[1.2rem] font-black uppercase leading-tight text-zinc-950">{entry.data.title}</h2>
          <span class="mt-2 block text-sm italic text-zinc-500">By {entry.data.author}</span>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-zinc-600 md:text-base">{entry.data.excerpt}</p>
          <div class="mt-5 flex justify-end">
            <ButtonLink href={`/news/${entry.slug}/`} label="Read more" variant="tertiary" size="sm" />
          </div>
        </article>
      ))}
    </div>
  </div>
  <div class="absolute inset-x-0 -bottom-px h-[calc(4rem+2px)] bg-tertiary-fixed">
    <div class="divider-angle-fill-reverse bg-primary-container"></div>
  </div>
</section>
