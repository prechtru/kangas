---
import { getCollection } from "astro:content";
import NewsList from "../../components/NewsList.astro";
import PageHeader from "../../components/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const news = (await getCollection("news")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout title="News | Nunawading Kangas" description="News, updates, and announcements from Nunawading Kangas Basketball Club.">
  <div class="hero-gradient-surface min-h-screen">
    <PageHeader
      eyebrow="Club News"
      title="News"
      summary="Announcements, game day notes, registration updates, and community stories from around the Kangas."
    />
    <NewsList entries={news} />
  </div>
</BaseLayout>
