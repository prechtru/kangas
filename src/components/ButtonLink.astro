---
import { withBase } from "../lib/withBase";
import { externalLinkAttrs } from "../lib/linkAttrs";

interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary" | "tertiary";
  size?: "sm" | "md" | "lg";
}

const { href, label, variant = "primary", size = "md" } = Astro.props;
const variantClass = {
  primary: "cta-primary-button",
  secondary: "cta-secondary-button",
  tertiary: "cta-tertiary-button"
}[variant];
const sizeClass = {
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-3 text-base",
  lg: "px-10 py-4 text-xl"
}[size];
---

<a class={`parallelogram inline-flex whitespace-nowrap ${variantClass} ${sizeClass}`} href={withBase(href)} {...externalLinkAttrs(href)}>
  <span class="skew-fix block whitespace-nowrap font-black italic uppercase tracking-wide">{label}</span>
</a>
