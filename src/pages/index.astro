---
import { getCollection, getEntry } from "astro:content";
import AgeGroups from "../components/AgeGroups.astro";
import HeroBanner from "../components/HeroBanner.astro";
import NewsTimeline from "../components/NewsTimeline.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const home = await getEntry("pages", "home");
const ageGroups = await getEntry("age-groups", "main");

if (!home) {
  throw new Error("Missing home page content entry.");
}

if (!ageGroups) {
  throw new Error("Missing age groups content entry.");
}

const latestNews = (await getCollection("news"))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, home.data.newsSection.limit);
---

<BaseLayout title={home.data.metaTitle ?? home.data.title} description={home.data.metaDescription}>
  <HeroBanner {...home.data.hero} />
  <NewsTimeline entries={latestNews} {...home.data.newsSection} />
  <AgeGroups {...ageGroups.data} />
</BaseLayout>
